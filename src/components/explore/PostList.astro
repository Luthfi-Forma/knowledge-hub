---
import type { CollectionEntry } from 'astro:content';
import EmptyState from '../EmptyState.astro';
import PostListItem from '../PostListItem.astro';

interface Props {
  posts: CollectionEntry<'posts'>[];
  emptyMessage: string;
}

const { posts, emptyMessage } = Astro.props;
---

{
  posts.length === 0 ? (
    <EmptyState message={emptyMessage} ctaHref="/explore" ctaLabel="Back to all" />
  ) : (
    <div class="flex flex-col border-b border-line">
      {posts.map((post) => (
        <PostListItem post={post} href={`/posts/${post.id}`} headingLevel="h2" />
      ))}
    </div>
  )
}
