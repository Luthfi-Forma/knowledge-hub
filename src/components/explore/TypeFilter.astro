---
import { POST_TYPES } from '../../lib/posts';

interface Props {
  active: 'all' | (typeof POST_TYPES)[number];
}

const { active } = Astro.props;

const tabs = [
  { key: 'all' as const, href: '/explore', label: 'All' },
  ...POST_TYPES.map((type) => ({
    key: type,
    href: `/explore/${type}`,
    label: type.charAt(0).toUpperCase() + type.slice(1),
  })),
];
---

<nav aria-label="Filter by type" class="mb-5 flex flex-wrap gap-2">
  {
    tabs.map((tab) => (
      <a
        href={tab.href}
        aria-current={tab.key === active ? 'page' : undefined}
        class:list={[
          'inline-flex min-h-11 items-center rounded-md border px-3.5 text-sm font-medium focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent',
          tab.key === active
            ? 'border-ink bg-ink text-paper'
            : 'border-line text-ink hover:border-ink',
        ]}
      >
        {tab.label}
      </a>
    ))
  }
</nav>
