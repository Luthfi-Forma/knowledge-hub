---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  href?: string;
}

const { post, href } = Astro.props;
const { title, summary, cover, date, type } = post.data;
const formattedDate = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const typeLabel = type.charAt(0).toUpperCase() + type.slice(1);
---

<article class="group">
  <a href={href ?? undefined} aria-disabled={href ? undefined : 'true'} class="block focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
    {
      cover ? (
        <Image
          src={cover}
          alt=""
          class="aspect-4/3 w-full rounded-sm object-cover"
          widths={[400, 800]}
          sizes="(min-width: 768px) 388px, 100vw"
        />
      ) : (
        <div class="flex aspect-4/3 w-full items-center justify-center rounded-sm bg-paper-raised text-xs text-ink-muted">
          {typeLabel}
        </div>
      )
    }
    <p class="mt-3 text-xs tracking-wide text-accent uppercase">{formattedDate} · {typeLabel}</p>
    <h3 class="mt-1.5 text-lg leading-snug text-ink group-hover:text-accent">{title}</h3>
    <p class="mt-1.5 text-sm leading-normal text-ink-muted">{summary}</p>
  </a>
</article>
