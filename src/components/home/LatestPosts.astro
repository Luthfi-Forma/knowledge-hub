---
import type { CollectionEntry } from 'astro:content';
import SectionHeading from '../SectionHeading.astro';
import EmptyState from '../EmptyState.astro';
import PostListItem from '../PostListItem.astro';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
---

<section class="border-b border-line py-8">
  <div class="mx-auto max-w-(--container-content) px-5">
    <SectionHeading title="Latest posts" href="/explore" />
    {
      posts.length === 0 ? (
        <EmptyState message="Nothing published yet." />
      ) : (
        <div class="flex flex-col gap-6">
          {posts.map((post) => (
            <PostListItem post={post} />
          ))}
        </div>
      )
    }
  </div>
</section>
