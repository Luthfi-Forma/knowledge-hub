---
import type { CollectionEntry } from 'astro:content';
import SectionHeading from '../SectionHeading.astro';
import EmptyState from '../EmptyState.astro';
import PostCard from '../PostCard.astro';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
---

<section class="border-b border-line bg-paper py-8">
  <div class="mx-auto max-w-(--container-content) px-5">
    <SectionHeading title="Featured projects" href="/explore/project" />
    {
      posts.length === 0 ? (
        <EmptyState
          message="Case studies are being written up — check back soon."
          ctaHref="/explore"
          ctaLabel="See what's published"
        />
      ) : (
        <div class="relative">
          <ul data-carousel-track class="flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2">
            {posts.map((post) => (
              <li class="w-[78vw] flex-none snap-start sm:w-[340px]">
                <PostCard post={post} href={`/posts/${post.id}`} />
              </li>
            ))}
          </ul>
          {posts.length > 1 && (
            <div class="mt-3 flex justify-end gap-2">
              <button
                type="button"
                data-carousel-prev
                aria-label="Previous project"
                class="flex h-9 w-9 items-center justify-center border border-line text-ink-muted hover:border-ink hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:pointer-events-none disabled:opacity-30"
              >
                ←
              </button>
              <button
                type="button"
                data-carousel-next
                aria-label="Next project"
                class="flex h-9 w-9 items-center justify-center border border-line text-ink-muted hover:border-ink hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:pointer-events-none disabled:opacity-30"
              >
                →
              </button>
            </div>
          )}
        </div>
      )
    }
  </div>
</section>

<style>
  /*
   * Hide the scrollbar but keep the track natively scrollable — this is the
   * no-JS fallback (ADR-002 tier 2): touch/trackpad swipe works with zero
   * script. The script below layers mouse click-drag and the prev/next
   * buttons on top.
   */
  [data-carousel-track] {
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  [data-carousel-track]::-webkit-scrollbar {
    display: none;
  }
  [data-carousel-track].is-dragging {
    scroll-snap-type: none;
    cursor: grabbing;
    user-select: none;
  }
</style>

<script>
  function initCarousel(track: HTMLElement) {
    const section = track.closest('.relative');
    const prevBtn = section?.querySelector<HTMLButtonElement>('[data-carousel-prev]');
    const nextBtn = section?.querySelector<HTMLButtonElement>('[data-carousel-next]');

    const updateButtons = () => {
      if (!prevBtn || !nextBtn) return;
      const max = track.scrollWidth - track.clientWidth - 1;
      prevBtn.disabled = track.scrollLeft <= 0;
      nextBtn.disabled = track.scrollLeft >= max;
    };

    const scrollByCard = (dir: 1 | -1) => {
      const card = track.querySelector<HTMLElement>('li');
      const amount = (card?.offsetWidth ?? track.clientWidth * 0.8) + 16;
      track.scrollBy({ left: dir * amount, behavior: 'smooth' });
    };

    prevBtn?.addEventListener('click', () => scrollByCard(-1));
    nextBtn?.addEventListener('click', () => scrollByCard(1));
    track.addEventListener('scroll', updateButtons, { passive: true });
    updateButtons();

    // Click-and-drag for mouse users; touch/trackpad already scroll natively.
    let dragging = false;
    let moved = false;
    let startX = 0;
    let startScroll = 0;

    track.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'mouse') return;
      dragging = true;
      moved = false;
      startX = e.clientX;
      startScroll = track.scrollLeft;
      track.classList.add('is-dragging');
      track.setPointerCapture(e.pointerId);
    });

    track.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 3) moved = true;
      track.scrollLeft = startScroll - dx;
    });

    const endDrag = () => {
      if (!dragging) return;
      dragging = false;
      track.classList.remove('is-dragging');
      if (moved) {
        // A drag just happened — swallow the click it triggers so the
        // card link underneath the pointer doesn't navigate accidentally.
        const suppressClick = (ce: MouseEvent) => {
          ce.preventDefault();
          ce.stopPropagation();
        };
        track.addEventListener('click', suppressClick, { capture: true, once: true });
      }
    };
    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointercancel', endDrag);
  }

  document.querySelectorAll<HTMLElement>('[data-carousel-track]').forEach(initCarousel);
</script>
