---
interface Props {
  message: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const { message, ctaHref, ctaLabel } = Astro.props;
---

<div class="rounded-lg border border-dashed border-line px-6 py-8 text-center text-sm text-ink-muted">
  <p>
    {message}
    {
      ctaHref && ctaLabel && (
        <>
          {' '}
          <a href={ctaHref} class="text-accent hover:underline">
            {ctaLabel}
          </a>
        </>
      )
    }
  </p>
</div>
