---
interface Props {
  title: string;
  href?: string;
  linkLabel?: string;
}

const { title, href, linkLabel = 'See more' } = Astro.props;
---

<div class="mb-4 flex items-baseline justify-between">
  <h2 class="font-display text-xl text-ink underline decoration-1 underline-offset-4">{title}</h2>
  {
    href && (
      <a
        href={href}
        class="text-xs font-medium tracking-wide text-ink-muted uppercase hover:text-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        {linkLabel} →
      </a>
    )
  }
</div>
