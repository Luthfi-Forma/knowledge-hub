---
interface Section {
  slug: string;
  text: string;
  depth: number;
}

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

<nav aria-label="On this page" class="mb-8 border border-line px-5 py-4">
  <p class="mb-2.5 text-xs font-medium tracking-wide text-ink-muted uppercase">On this page</p>
  <ol class="flex flex-wrap gap-x-5 gap-y-1.5 text-sm">
    {
      sections.map((section) => (
        <li>
          <a
            href={`#${section.slug}`}
            class="text-ink-muted hover:text-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            {section.text}
          </a>
        </li>
      ))
    }
  </ol>
</nav>
