---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmptyState from '../../components/EmptyState.astro';
import { getProjectSlugs, getPostsByProject } from '../../lib/posts';

const slugs = await getProjectSlugs();
const projects = await Promise.all(
  slugs.map(async (slug) => {
    const posts = await getPostsByProject(slug);
    const title = slug.replace(/-/g, ' ').replace(/\b\w/g, (char: string) => char.toUpperCase());
    return { slug, title, count: posts.length };
  }),
);
---

<BaseLayout title="Projects — Afreza Hernanda">
  <section class="mx-auto max-w-(--container-content) px-5 py-8">
    <h1 class="font-display mb-5 text-xl font-bold text-ink">Projects</h1>
    {
      projects.length === 0 ? (
        <EmptyState message="No projects published yet." ctaHref="/explore" ctaLabel="See what's published" />
      ) : (
        <ul class="divide-y divide-line border-y border-line">
          {projects.map((project) => (
            <li>
              <a
                href={`/projects/${project.slug}`}
                class="flex min-h-11 items-center justify-between gap-4 py-3 text-ink hover:text-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
              >
                <span class="font-medium">{project.title}</span>
                <span class="text-sm text-ink-muted">{project.count} {project.count === 1 ? 'post' : 'posts'}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
