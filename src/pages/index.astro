---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import FeaturedProjects from '../components/home/FeaturedProjects.astro';
import LatestPosts from '../components/home/LatestPosts.astro';
import Contact from '../components/Contact.astro';
import { getFeaturedProjects, getLatestPosts } from '../lib/posts';

const featuredProjects = await getFeaturedProjects();
const latestPosts = await getLatestPosts();
---

<BaseLayout title="Afreza Hernanda — knowledge-hub">
  <Hero />
  <FeaturedProjects posts={featuredProjects} />
  <LatestPosts posts={latestPosts} />
  <Contact />
</BaseLayout>
