---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostListItem from '../../components/PostListItem.astro';
import EmptyState from '../../components/EmptyState.astro';
import { getAllTags, getPostsByTag } from '../../lib/posts';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map(({ tag }) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const posts = await getPostsByTag(tag);
---

<BaseLayout title={`#${tag} — Afreza Hernanda`} description={`Posts tagged ${tag}.`}>
  <section class="mx-auto max-w-(--container-content) px-5 py-8">
    <h1 class="font-display mb-5 text-2xl font-extrabold text-ink">#{tag}</h1>
    {
      posts.length === 0 ? (
        <EmptyState message={`No posts tagged "${tag}" yet.`} ctaHref="/tags" ctaLabel="Browse all tags" />
      ) : (
        <div class="flex flex-col border-b border-line">
          {posts.map((post) => (
            <PostListItem post={post} href={`/posts/${post.id}`} headingLevel="h2" />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
