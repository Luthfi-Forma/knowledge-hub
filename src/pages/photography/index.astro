---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmptyState from '../../components/EmptyState.astro';
import PhotoTile from '../../components/PhotoTile.astro';
import { getPhotos } from '../../lib/posts';

const photos = await getPhotos();
---

<BaseLayout title="Photography — Afreza Hernanda" description="A photo collection from fieldwork and travel.">
  <section class="mx-auto max-w-(--container-content) px-5 py-8">
    <h1 class="font-display mb-5 text-2xl font-extrabold text-ink">Photography</h1>
    {
      photos.length === 0 ? (
        <EmptyState message="No photos published yet." ctaHref="/explore" ctaLabel="See what's published" />
      ) : (
        <div class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 lg:grid-cols-4">
          {photos.map((photo) => (
            <PhotoTile post={photo} href={`/posts/${photo.id}`} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
