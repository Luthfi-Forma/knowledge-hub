---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TypeFilter from '../../components/explore/TypeFilter.astro';
import PostList from '../../components/explore/PostList.astro';
import { getPublishedPosts } from '../../lib/posts';

const posts = await getPublishedPosts();
---

<BaseLayout title="Explore — Afreza Hernanda">
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <section class="mx-auto max-w-(--container-content) px-5 py-8">
    <h1 class="font-display mb-5 text-xl font-bold text-ink">Explore</h1>
    <div id="search" class="mb-6"></div>
    <TypeFilter active="all" />
    <PostList posts={posts} emptyMessage="Nothing published yet." />
  </section>
</BaseLayout>

<script>
  // Pagefind's search bundle (/pagefind/pagefind-ui.js + pagefind-ui.css) is generated by
  // `pagefind --site dist`, which runs as a post-build step after `astro build` (see the
  // "build" script in package.json). Those assets only exist in the built dist/ output —
  // they 404 during `astro dev`, which has no dist/ to index. That 404 is expected, not a
  // bug: search only works after `npm run build` + serving the dist/ folder (e.g. `astro
  // preview`).
  //
  // Loaded via a plain <script src> element (not a dynamic `import()`) because
  // pagefind-ui.js is a classic script — it attaches itself to `window.PagefindUI`
  // rather than exposing an ES module export — and because a Vite-analyzed `import()`
  // of a public/ asset path drags in Vite's modulepreload helper, which throws before
  // the request even fires. onerror below swallows the expected 404 in dev.
  const pagefindScript = document.createElement('script');
  pagefindScript.src = '/pagefind/pagefind-ui.js';
  pagefindScript.onload = () => {
    // @ts-expect-error - PagefindUI is a runtime global from the script loaded above
    new window.PagefindUI({ element: '#search', showSubResults: true });
  };
  pagefindScript.onerror = () => {
    // No-op: expected in `astro dev` before the search index has been built.
  };
  document.head.appendChild(pagefindScript);
</script>
