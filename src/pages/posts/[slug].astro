---
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getPublishedPosts, getRelatedPosts } from '../../lib/posts';
import CikarangIndustrialSettlementScrollytelling from '../../lib/scrollytelling/cikarang-industrial-settlement-pattern';

// ADR-002: each scrollytelling post is a bespoke wired-up React island (data
// + viz + shell). Astro's `client:*` hydration needs a statically-analyzable
// import reference in the template — not a variable assigned at runtime from
// a lookup map — so a new scrollytelling post gets its own explicit branch
// here rather than a generic slug → component registry. To add one:
//   1. Static-import the post's wired-up island component below (see
//      CikarangIndustrialSettlementScrollytelling).
//   2. Add a branch next to the existing one, further down this file:
//      {isScrollytelling && post.id === '<slug>' && <Component client:visible />}

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, summary, date, type, tags, project, repo, demo, cover } = post.data;
const { Content, headings } = await render(post);
const relatedPosts = await getRelatedPosts(post);
const formattedDate = date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const typeLabel = type.charAt(0).toUpperCase() + type.slice(1);
const wordCount = post.body?.trim().split(/\s+/).filter(Boolean).length ?? 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));
const sections = headings.filter((heading) => heading.depth === 2);
const isArticle = type === 'article';
const isScrollytelling = post.data.presentation === 'scrollytelling';
---

<BaseLayout title={`${title} — Afreza Hernanda`} description={summary} image={`/og/${post.id}.png`}>
  <article class="mx-auto max-w-(--container-content) px-5 py-10">
    <p class="mb-2.5 text-xs font-medium tracking-wide text-accent uppercase">
      {isScrollytelling ? `${typeLabel} · ${formattedDate}` : `${typeLabel} · ${readingMinutes} min read · ${formattedDate}`}
    </p>
    {!isScrollytelling && (
      <h1 class="font-display mb-4 text-3xl leading-[1.1] font-extrabold text-ink sm:text-4xl">{title}</h1>
    )}
    {!isScrollytelling && (
      <p class="font-display mb-6 max-w-[52ch] text-lg leading-relaxed text-ink-muted italic">{summary}</p>
    )}

    {
      !isScrollytelling && cover &&
        (type === 'photo' ? (
          <Image
            src={cover}
            alt={title}
            class="mb-8 max-h-[75vh] w-full rounded-sm object-contain"
            widths={[600, 1200]}
            sizes="(min-width: 800px) 800px, 100vw"
          />
        ) : (
          <Image
            src={cover}
            alt=""
            class="mb-8 aspect-video w-full rounded-sm object-cover"
            widths={[600, 1200]}
            sizes="(min-width: 800px) 800px, 100vw"
          />
        ))
    }

    {
      (project || repo || demo) && (
        <div class="mb-8 flex flex-wrap gap-x-5 gap-y-2 border-y border-line py-3 text-sm">
          {project && <span class="text-ink-muted">Project: {project}</span>}
          {repo && (
            <a href={repo} target="_blank" rel="noopener" class="text-accent hover:underline">
              Repository ↗
            </a>
          )}
          {demo && (
            <a href={demo} target="_blank" rel="noopener" class="text-accent hover:underline">
              Live demo ↗
            </a>
          )}
        </div>
      )
    }

    {!isScrollytelling && sections.length > 0 && <TableOfContents sections={sections} />}

    {!isScrollytelling && (
      <div class:list={['prose-content max-w-none text-[0.9375rem] leading-relaxed text-ink', isArticle && 'prose-article']}>
        <Content />
      </div>
    )}

    {isScrollytelling && post.id === 'cikarang-industrial-settlement-pattern' && (
      <CikarangIndustrialSettlementScrollytelling client:visible />
    )}

    {
      tags.length > 0 && (
        <div class="mt-10 flex flex-wrap gap-2 border-t border-line pt-6">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="inline-flex min-h-11 items-center border border-accent px-2.5 py-1 text-xs text-accent hover:bg-accent hover:text-paper focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
            >
              {tag}
            </a>
          ))}
        </div>
      )
    }

    <RelatedPosts posts={relatedPosts} />
  </article>
</BaseLayout>

<style>
  .prose-content {
    font-family: var(--font-display);
  }
  .prose-content :global(p) {
    margin-bottom: 1.25em;
  }
  .prose-content :global(h2) {
    margin-top: 2em;
    margin-bottom: 0.75em;
    font-size: 1.375rem;
    font-weight: 800;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 5px;
  }
  .prose-content :global(h3) {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    font-size: 1.125rem;
    font-weight: 800;
  }
  .prose-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin-bottom: 1.25em;
    padding-left: 1.5em;
  }
  .prose-content :global(ul) {
    list-style: disc;
  }
  .prose-content :global(ol) {
    list-style: decimal;
  }
  .prose-content :global(li) {
    margin-bottom: 0.375em;
  }
  .prose-content :global(code) {
    border-radius: 0.15em;
    background-color: var(--color-paper-raised);
    padding: 0.15em 0.4em;
    font-family: ui-monospace, "IBM Plex Mono", monospace;
    font-size: 0.875em;
  }
  .prose-content :global(pre) {
    margin-bottom: 1.25em;
    overflow-x: auto;
    border-radius: 0.2em;
    background-color: var(--color-paper-raised);
    padding: 1em;
  }
  .prose-content :global(pre code) {
    background: none;
    padding: 0;
  }
  .prose-content :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: 1em;
    color: var(--color-ink-muted);
    font-style: italic;
  }

  /*
   * Article-only reading polish (T-23): narrower measure, a Medium-style
   * drop cap on the opening paragraph, and a centered pull-quote treatment.
   * Scoped to .prose-article so project/research posts (which may carry
   * code blocks or need the full container width) are untouched.
   */
  .prose-article {
    max-width: var(--container-prose);
    margin-inline: auto;
  }
  .prose-article :global(p:first-of-type::first-letter) {
    float: left;
    margin-top: 0.03em;
    margin-right: 0.09em;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 3.4em;
    line-height: 0.8;
    color: var(--color-accent);
  }
  .prose-article :global(blockquote) {
    margin: 2em 0;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    border-left: none;
    padding: 1.5em 0;
    text-align: center;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-style: italic;
    line-height: 1.4;
  }
</style>

