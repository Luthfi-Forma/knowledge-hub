---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

interface ExperienceEntry {
  role: string;
  org: string;
  dates: string;
  description?: string;
}

const expertise = [
  {
    title: 'Spatial Analysis & GIS',
    description:
      'Turning raw geodata into decisions — building-footprint detection, kernel density, gravity and nearest-neighbour analysis, thematic mapping, and cartographic production.',
    chips: ['ArcGIS', 'QGIS', 'Google Earth Engine', 'Python', 'IBM SPSS'],
  },
  {
    title: 'Regional & Spatial Planning',
    description:
      'Technical drafting and revision of statutory plans — RTRW and RDTR — from data compilation through spatial direction and zoning.',
    chips: ['RTRW', 'RDTR', 'Land-Use Allocation'],
  },
  {
    title: 'Environmental Planning',
    description:
      'Environmental Protection & Management Plans (RPPLH): ecosystem-vulnerability inventory, biodiversity assessment, and reading development pressure on the land.',
    chips: ['RPPLH', 'Ecosystem Services', 'Biodiversity'],
  },
  {
    title: 'Social & Poverty Studies',
    description:
      'Community characteristic mapping and extreme-poverty targeting (P3KE), demographic profiling, and social-impact review of programs and infrastructure.',
    chips: ['P3KE Targeting', 'Demographics', 'Field Survey'],
  },
];

const documents = [
  { title: 'Purwakarta Regency in Figures 2023', org: 'BPS-Statistics' },
  { title: 'Regional Drinking-Water Strategy (Jakstrada SPAM)', org: 'Bappeda Lampung Timur' },
  { title: 'Jabung & Coastal Area Development', org: 'Bappeda Lampung Timur' },
  { title: 'RPPLH — South Papua Province', org: 'Ministry of Environment & Forestry' },
];

const experience: ExperienceEntry[] = [
  {
    role: 'Assistant to Expert',
    org: 'HAS Consulting · Jakarta',
    dates: 'Sep 2024 — Present',
    description:
      "Drafting the Environmental Protection & Management Plan (RPPLH) for South Papua — ecosystem-vulnerability analysis and a review of customary land affected by the Food Estate program.",
  },
  {
    role: 'Support Staff — Drafter',
    org: 'Dinas Cipta Karya & Penataan Ruang · Bekasi Regency',
    dates: 'Sep — Dec 2024',
    description: "Coordinated the technical-material revision of Bekasi Regency's 2022–2042 Regional Spatial Plan (RTRW).",
  },
  {
    role: 'GIS Operator & Drafter',
    org: 'CV. Hasta Tunggal Pratama · Bandar Lampung',
    dates: 'Apr — Aug 2024',
    description:
      "Drafted Lampung Timur's regional drinking-water strategy (Jakstrada SPAM) and ran a macro–micro gravity analysis for the Jabung coastal-area development plan.",
  },
  { role: 'GIS Team', org: 'Dinas PU & Tata Ruang · Kota Metro, Lampung', dates: 'Jan — Mar 2024' },
  { role: 'Analyst Intern', org: 'Ministry of Environment & Forestry (KLHK) · Remote', dates: 'Sep — Dec 2023' },
  {
    role: 'Urban & Regional Planning Intern',
    org: 'PT. Planosentris Nusantara · Samarinda',
    dates: 'Sep — Dec 2023',
    description:
      'Poverty assessment study, RDTR technical guidance for Bongan Regency, and spatial-order law enforcement work in Kutai Kartanegara.',
  },
  {
    role: 'GIS Team — Freelance',
    org: 'Ministry of Public Works (PUPR) · Jakarta',
    dates: 'Feb — Jun 2023',
    description: 'Feasibility study for the Panjang–Kota Agung toll road in Lampung.',
  },
  {
    role: 'Drafter — Freelance',
    org: 'BPS-Statistics · Purwakarta',
    dates: 'Dec 2022 — Jan 2023',
    description: 'Regional economic accounting and drafting for the Purwakarta Regency in Figures 2023 report.',
  },
  {
    role: 'Surveyor & Analyst Assistant',
    org: 'PT. Hutama Karya · South Lampung',
    dates: 'Mar — Apr 2022',
    description: 'Field survey and break-even point calculations for the Palembang–Betung toll road.',
  },
];

const organizations = [
  { role: 'Head of Technology & Professional Division', org: 'HMP Mandalanata, ITERA', dates: 'May 2023 — Jan 2024' },
  { role: 'Founding Member', org: 'Poliscape Planning Community', dates: 'Aug 2024 — Present' },
];
---

<BaseLayout title="About — Afreza Hernanda" description="About Afreza Luthfi Hernanda, Urban & Regional Planner — background, expertise, and experience.">
  <section class="mx-auto max-w-(--container-content) px-5 py-16">
    <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center">
      <img
        src="/portrait.png"
        alt="Portrait of Afreza Luthfi Hernanda"
        width="160"
        height="160"
        class="h-32 w-32 shrink-0 rounded-sm object-cover sm:h-40 sm:w-40"
      />
      <div>
        <p class="mb-2 text-xs font-medium tracking-wide text-accent uppercase">Urban &amp; Regional Planner</p>
        <h1 class="font-display mb-3 text-3xl font-extrabold text-ink sm:text-4xl">Afreza Luthfi Hernanda</h1>
        <p class="max-w-[48ch] text-sm leading-relaxed text-ink-muted">
          I read regions through their data — mapping how industry, environment, and communities
          compete for the same ground, so plans are built on evidence rather than assumption.
        </p>
      </div>
    </div>

    <div class="mt-8 max-w-[62ch] space-y-4 text-sm leading-relaxed text-ink">
      <p>
        I'm a Bachelor of Urban &amp; Regional Planning from Institut Teknologi Sumatera, with
        hands-on experience across spatial, environmental, and social planning. My work spans
        Regional Spatial Plans (RTRW), Environmental Protection &amp; Management Plans (RPPLH),
        coastal-area development, and provincial studies on extreme poverty.
      </p>
      <p>
        Driven by research and problem-solving, I'm comfortable working independently or steering
        a team toward a result that holds up in the field and on paper.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-(--container-content) px-5 pb-16">
    <SectionHeading title="Background" />
    <dl class="grid gap-6 sm:grid-cols-3">
      <div>
        <dt class="text-xs font-medium text-ink-muted">Education</dt>
        <dd class="mt-1.5 text-sm text-ink">
          <strong class="font-semibold">Institut Teknologi Sumatera</strong><br />
          B.Eng., Urban &amp; Regional Planning · 2020–2024
          <span class="mt-1 block text-xs text-ink-muted">SMAN 1 Tambun Selatan · Science · 2017–2020</span>
        </dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-ink-muted">Languages</dt>
        <dd class="mt-1.5 text-sm text-ink">
          Indonesian — Native<br />
          English — B2, Independent User
        </dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-ink-muted">Location</dt>
        <dd class="mt-1.5 text-sm text-ink">
          Cikarang Selatan, Bekasi<br />
          West Java, Indonesia
        </dd>
      </div>
    </dl>
  </section>

  <section class="mx-auto max-w-(--container-content) px-5 pb-16">
    <SectionHeading title="Expertise" />
    <div class="grid gap-6 sm:grid-cols-2">
      {
        expertise.map((area) => (
          <div class="rounded-sm border border-line p-5">
            <h3 class="text-lg text-ink">{area.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">{area.description}</p>
            <ul class="mt-3 flex flex-wrap gap-1.5">
              {area.chips.map((chip) => (
                <li class="inline-flex items-center border border-line px-2.5 py-1 text-xs text-ink-muted">
                  {chip}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-(--container-content) px-5 pb-16">
    <SectionHeading title="Official Documents" />
    <p class="mb-4 max-w-[62ch] text-sm leading-relaxed text-ink-muted">
      Technical documents and studies I contributed to that were published by government agencies
      and ministries.
    </p>
    <ul class="space-y-3">
      {
        documents.map((doc) => (
          <li class="rounded-sm border border-line px-4 py-3">
            <p class="text-sm font-semibold text-ink">{doc.title}</p>
            <p class="mt-0.5 text-xs text-ink-muted">{doc.org}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mx-auto max-w-(--container-content) px-5 pb-16">
    <SectionHeading title="Experience" />
    <p class="mb-5 text-xs text-ink-muted">Roles with a description can be expanded for detail.</p>
    <ol class="relative ml-1 border-l border-line">
      {
        experience.map((xp) =>
          xp.description ? (
            <li class="relative pb-7 pl-6 last:pb-0">
              <span class="absolute top-1.5 -left-[5px] h-2.5 w-2.5 rounded-full bg-accent" aria-hidden="true" />
              <details>
                <summary class="flex cursor-pointer list-none flex-wrap items-baseline justify-between gap-x-4 gap-y-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
                  <span class="min-w-0">
                    <span class="font-display block text-lg text-ink">
                      {xp.role}
                      <span class="timeline-marker ml-1.5 text-accent" aria-hidden="true">
                        +
                      </span>
                    </span>
                    <span class="block text-xs text-ink-muted">{xp.org}</span>
                  </span>
                  <span class="shrink-0 text-xs text-ink-muted">{xp.dates}</span>
                </summary>
                <p class="mt-2 max-w-[58ch] text-sm leading-relaxed text-ink-muted">{xp.description}</p>
              </details>
            </li>
          ) : (
            <li class="relative pb-7 pl-6 last:pb-0">
              <span class="absolute top-1.5 -left-[5px] h-2.5 w-2.5 rounded-full border border-line bg-paper" aria-hidden="true" />
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <span class="min-w-0">
                  <span class="font-display block text-lg text-ink">{xp.role}</span>
                  <span class="block text-xs text-ink-muted">{xp.org}</span>
                </span>
                <span class="shrink-0 text-xs text-ink-muted">{xp.dates}</span>
              </div>
            </li>
          ),
        )
      }
    </ol>

    <p class="mt-10 mb-3 text-xs font-medium tracking-wide text-ink-muted uppercase">Organizations</p>
    <ol class="space-y-3">
      {
        organizations.map((xp) => (
          <li class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 border-b border-line pb-3">
            <div class="min-w-0">
              <p class="font-display text-base text-ink">{xp.role}</p>
              <p class="text-xs text-ink-muted">{xp.org}</p>
            </div>
            <p class="shrink-0 text-xs text-ink-muted">{xp.dates}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="mx-auto max-w-(--container-content) px-5 pb-16 text-center">
    <p class="text-sm text-ink-muted">
      Want to collaborate? Reach out via the <a href="/#contact" class="text-accent hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">contact</a> section
      on the homepage.
    </p>
  </section>
</BaseLayout>

<style>
  .timeline-marker {
    display: inline-block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .timeline-marker {
      transition: transform 200ms ease;
    }

    details[open] > summary .timeline-marker {
      transform: rotate(45deg);
    }
  }
</style>
