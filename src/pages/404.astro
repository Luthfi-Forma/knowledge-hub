---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Afreza Hernanda">
  <section class="mx-auto max-w-(--container-content) px-5 py-16 text-center">
    <p class="mb-2.5 text-xs font-medium text-ink-muted">404</p>
    <h1 class="font-display mb-3.5 text-2xl font-bold text-ink sm:text-3xl">Page not found</h1>
    <p class="mx-auto mb-6 max-w-[38ch] text-sm leading-relaxed text-ink-muted">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a
      href="/"
      class="inline-flex min-h-11 items-center rounded-md bg-ink px-5 text-sm font-semibold text-paper hover:bg-ink-muted focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
